{
  "schema": "2.0",
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "text_size": "heading",
      "content": {{.Title | json}}
    },
    "template": "blue"
  },
  "body": {
    "elements": [
      {
        "tag": "div",
        "fields": [
          {{- range $index, $field := .Fields}}
          {
            "is_short": {{.IsShort}},
            "text": {
              "tag": {{ .Tag | json }},
              "content": {{ .Content | json }}
            }
          }{{if not (last $index $.Fields)}},{{end}}
          {{- end}}
        ]
      }
      {{- if not .HideForm }},
      {
        "tag": "hr"
      },
      {
        "tag": "form",
        "name": "approval",
        "elements": [
          {{- range $rowIndex, $row := .InputRows}}
          {
            "tag": "column_set",
            "flex_mode": {{ if eq (len $row) 1 }}"none"{{else}}"bisect"{{end}},
            "background_style": "default",
            "horizontal_spacing": "8px",
            "columns": [
              {{- range $colIndex, $input := $row}}
              {
                "tag": "column",
                "width": "weighted",
                "weight": 1,
                "vertical_align": "top",
                "elements": [
                  {
                    "tag": "div",
                    "text": {
                      "tag": "lark_md",
                      "content": {{ if $input.Required }}{{ printf "%s*" $input.Name | json }}{{ else }}{{ $input.Name | json }}{{ end }}
                    }
                  }
                  {{- if $input.Readonly }}
                  ,{
                    "tag": "div",
                    "text": {
                      "tag": "lark_md",
                      "content": {{ printf "<font color='grey'>%s</font>" $input.Value | json }}
                    }
                  }
                  {{- else if or (eq $input.Type "input") (eq $input.Type "textarea") (eq $input.Type "number") }}
                  ,{
                    "tag": "input",
                    "name": {{ $input.Key | json }},
                    "placeholder": {
                      "tag": "plain_text",
                      "content": {{ if and $input.Props (index $input.Props "placeholder") }}{{ index $input.Props "placeholder" | json }}{{ else }}{{ printf "请输入%s" $input.Name | json }}{{ end }}
                    },
                    "width": "fill",
                    "required": false
                  }
                  {{- else if eq $input.Type "date" }}
                  ,{
                    "tag": "picker_datetime",
                    "name": {{ $input.Key | json }},
                    "placeholder": {
                      "tag": "plain_text",
                      "content": {{ if and $input.Props (index $input.Props "placeholder") }}{{ index $input.Props "placeholder" | json }}{{ else }}{{ printf "请选择%s" $input.Name | json }}{{ end }}
                    },
                    "width": "default",
                    "required": false
                  }
                  {{- else if eq $input.Type "select" }}
                  ,{
                    "tag": "select_static",
                    "name": {{ $input.Key | json }},
                    "placeholder": {
                      "tag": "plain_text",
                      "content": {{ if and $input.Props (index $input.Props "placeholder") }}{{ index $input.Props "placeholder" | json }}{{ else }}{{ printf "请选择%s" $input.Name | json }}{{ end }}
                    },
                    "options": [
                      {{- range $optIndex, $opt := $input.Options}}
                      {
                        "text": {
                          "tag": "plain_text",
                          "content": {{ $opt.Label | json }}
                        },
                        "value": {{ $opt.Value | json }}
                      }{{if not (last $optIndex $input.Options)}},{{end}}
                      {{- end}}
                    ],
                    "width": "default",
                    "required": false
                  }
                  {{- else if eq $input.Type "multi_select" }}
                  ,{
                    "tag": "multi_select_static",
                    "name": {{ $input.Key | json }},
                    "placeholder": {
                      "tag": "plain_text",
                      "content": {{ if and $input.Props (index $input.Props "placeholder") }}{{ index $input.Props "placeholder" | json }}{{ else }}{{ printf "请选择%s" $input.Name | json }}{{ end }}
                    },
                    "options": [
                      {{- range $optIndex, $opt := $input.Options}}
                      {
                        "text": {
                          "tag": "plain_text",
                          "content": {{ $opt.Label | json }}
                        },
                        "value": {{ $opt.Value | json }}
                      }{{if not (last $optIndex $input.Options)}},{{end}}
                      {{- end}}
                    ],
                    "width": "default",
                    "required": false
                  }
                  {{- end}}
                ]
              }{{if not (last $colIndex $row)}},{{end}}
              {{- end}}
            ]
          },
          {{- end}}
          {{- if .InputRows }}
          {
            "tag": "hr"
          },
          {{- end}}
          {
            "tag": "input",
            "name": "comment",
            "placeholder": {
              "tag": "plain_text",
              "content": "请输入审批备注，选填"
            },
            "max_length": 200,
            "width": "fill",
            "required": false
          }
          {{- if .Tips }},
          {
            "tag": "markdown",
            "content": {{ $tips := "" }}{{ range $i, $tip := .Tips }}{{ if $i }}{{ $tips = printf "%s\n" $tips }}{{ end }}{{ $tips = printf "%s**💡 提示：** %s" $tips $tip }}{{ end }}{{ $tips | json }},
            "text_align": "left",
            "text_size": "notation"
          }
          {{- end}},
          {
            "tag": "column_set",
            "flex_mode": "bisect",
            "background_style": "default",
            "horizontal_spacing": "8px",
            "horizontal_align": "right",
            "columns": [
              {
                "tag": "column",
                "width": "auto",
                "vertical_align": "top",
                "elements": [
                  {
                    "tag": "button",
                    "action_type": "form_submit",
                    "name": "pass",
                    "text": {
                      "content": "批准",
                      "tag": "lark_md"
                    },
                    "value": {
                      {{- range $index, $callback := .CallbackValue}}
                      {{ $callback.Key | json }}: {{ printf "%v" $callback.Value | json }}{{if not (last $index $.CallbackValue)}},{{end}}
                      {{- end}}
                    },
                    "type": "primary"
                  }
                ]
              },
              {
                "tag": "column",
                "width": "auto",
                "vertical_align": "top",
                "elements": [
                  {
                    "tag": "button",
                    "action_type": "form_submit",
                    "name": "reject",
                    "text": {
                      "content": "拒绝",
                      "tag": "lark_md"
                    },
                    "value": {
                      {{- range $index, $callback := .CallbackValue}}
                      {{ $callback.Key | json }}: {{ printf "%v" $callback.Value | json }}{{if not (last $index $.CallbackValue)}},{{end}}
                      {{- end}}
                    },
                    "type": "danger"
                  }
                ]
              }
            ],
            "margin": "12px 0px 0px 0px"
          }
        ]
      }
      {{- end }}
    ]
  }
}