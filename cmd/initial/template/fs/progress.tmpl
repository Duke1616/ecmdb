{
  "schema": "2.0",
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "text_size": "heading",
      "content": {{.Title | json}}
    },
    "template": "green"
  },
  "body": {
    "elements": [
      {
        "tag": "div",
        "fields": [
          {{- range $index, $field := .Fields}}
          {
            "is_short": {{.IsShort}},
            "text": {
              "tag": {{ .Tag | json }},
              "content": {{ .Content | json }}
            }
          }{{if not (last $index $.Fields)}},{{end}}
          {{- end}}
        ]
      },
      {
        "tag": "hr"
      },
      {
        "tag": "div",
        "icon": {
          "tag": "standard_icon",
          "token": "succeed_filled",
          "color": "green"
        },
        "text": {
          "tag": "lark_md",
          "content": {{ .WantContent | json }}
        },
        "extra": {
          "tag": "button",
          "text": {
            "tag": "lark_md",
            "content": "查看进度"
          },
          "name": "progress",
          "value": {
            {{- range $index, $callback := .CallbackValue}}
            {{ $callback.Key | json }}: {{ printf "%v" $callback.Value | json }}{{if not (last $index $.CallbackValue)}},{{end}}
            {{- end}}
          },
          "type": "laser",
          "size": "medium"
        }
      }
    ]
  }
}