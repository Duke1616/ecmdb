{
  "schema": "2.0",
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "text_size": "heading",
      "content": {{.Title | json}}
    },
    "template": "green"
  },
  "body": {
    "elements": [
      {
        "tag": "column_set",
        "flex_mode": "none",
        "background_style": "default",
        "columns": [
          {{- range $index, $field := .Fields}}
          {
            "tag": "column",
            "width": "weighted",
            "weight": 1,
            "vertical_align": "top",
            "elements": [
              {
                "tag": {{ .Tag | json }},
                "content": {{ .Content | json }}
              }
            ]
          }{{if not (last $index $.Fields)}},{{end}}
          {{- end}}
        ]
      },
      {
        "tag": "hr"
      },
      {
        "tag": "img",
        "img_key": {{ .ImageKey | json }},
        "alt": {
          "tag": "plain_text",
          "content": ""
        },
        "mode": "fit_horizontal",
        "preview": true,
        "compact_width": false
      }
    ]
  }
}